							<p>{{ players[1].getCards()|length }}</p>
						</div>
					</div>
					<ul class="player-cards enemy-cards" id="enemy-cards1">
						{% for card in players[1].getCards() %}
							<li>
								<div class="card" id="card-{{ card.getId() }}">
									<div class="card-inner">
										<div class="card-front card-{{ card.getColor() }}">
											<p>
												{% if card.getNumber() === 12 %}
													+2
												{% elseif card.getNumber() === 11 %}
													⇵
												{% elseif card.getNumber() === 10 %}
													⊘
												{% else %}
													{{ card.getNumber() }}
												{% endif %}
											</p>
										</div>
										<div class="card-back"></div>
									</div>
								</div>
							</li>
						{% endfor %}
					</ul>
				</li>
				<li class="player-area enemy-area" id="enemy2-area">
					<div class="infos {% if turn.getId() === players[2].getId() %}actual-turn{% endif %}">
						<div class="player-identity">
							<p>{{ players[2].getName() }}</p>
							<img src="" alt="">
						</div>
						<div class="cards-counter">
							<p>{{ players[2].getCards()|length }}</p>
						</div>
					</div>
					<ul class="player-cards enemy-cards" id="enemy-cards2">
						{% for card in players[2].getCards() %}
							<li>
								<div class="card" id="card-{{ card.getId() }}">
									<div class="card-inner">
										<div class="card-front card-{{ card.getColor() }}">
											<p>
												{% if card.getNumber() === 12 %}
													+2
												{% elseif card.getNumber() === 11 %}
													⇵
												{% elseif card.getNumber() === 10 %}
													⊘
												{% else %}
													{{ card.getNumber() }}
												{% endif %}
											</p>
										</div>
										<div class="card-back"></div>
									</div>
								</div>
							</li>
						{% endfor %}
					</ul>
				</li>
				<li class="player-area enemy-area" id="enemy3-area">
					<div class="infos {% if turn.getId() === players[3].getId() %}actual-turn{% endif %}">
						<div class="player-identity">
							<p>{{ players[3].getName() }}</p>
							<img src="" alt="">
						</div>
						<div class="cards-counter">
							<p>{{ players[3].getCards()|length }}</p>
						</div>
					</div>
					<ul class="player-cards enemy-cards" id="enemy-cards3">
						{% for card in players[3].getCards() %}
							<li>
								<div class="card" id="card-{{ card.getId() }}">
									<div class="card-inner">
										<div class="card-front card-{{ card.getColor() }}">
											<p>
												{% if card.getNumber() === 12 %}
													+2
												{% elseif card.getNumber() === 11 %}
													⇵
												{% elseif card.getNumber() === 10 %}
													⊘
												{% else %}
													{{ card.getNumber() }}
												{% endif %}
											</p>
										</div>
										<div class="card-back"></div>
									</div>
								</div>
							</li>
						{% endfor %}
					</ul>
				</li>
			</ul>
		</div>
		<div class="game-animation-container">
			<div class="card-container"></div>
		</div>
		<div class="game-hud">
			<h1>Play</h1>
			<a href="{{ path('start_index')}}" class="button">Reset</a>
		</div>
		{# <p>Sens :
								{% if sens === 1 %}Normal{% else %}Inversé
								{% endif %}
							</p>
							<p>
								Accumulation :
								{{ accumulation }}
							</p>
							<p>Deck :
								{{ deck|length }}
								cartes</p>
							{% if turn.getPlayerType() === 'user' and cardPicked === false %}
								<a href="{{ path('deck_index', {'playerId': turn.getId()}) }}">Piocher-
									{% if cardPicked === true %}CardPicked true{% elseif cardPicked === false %}CardPicked false{% elseif cardPicked === null %}CardPicked null
									{% endif %}
								</a>
							{% else %}
								<p>Piocher -
									{% if cardPicked === true %}CardPicked true{% elseif cardPicked === false %}CardPicked false{% elseif cardPicked === null %}CardPicked null
									{% endif %}
								</p>
							{% endif %}
							<p>Ordre des joueurs :</p>
							<ul style="display: flex; gap: 40px">
								{% for player in players %}
									{% if turn.getId() === player.getId() %}
										<a href="">
											<li>
												<p>{{ player.getName() }}
													- Cartes :
													{{ player.getCards()|length }}</p>
											</li>
										</a>
									{% else %}
										<li>
											<p>{{ player.getName() }}
												- Cartes :
												{{ player.getCards()|length }}</p>
										</li>
									{% endif %}
								{% endfor %}
							</ul>
							{% if enemyCardPlayed %}
								<p>Carte ennemie jouée :
									{{ enemyCardPlayed.getColor() }}
									-
									{{ enemyCardPlayed.getNumber() }}
									{% if enemyCardPlayed.getNumber() === 12 %}- Carte + 2 !
									{% endif %}
									{% if enemyCardPlayed.getNumber() === 11 %}- Carte Changement de sens !
									{% endif %}
									{% if enemyCardPlayed.getNumber() === 10 %}- Carte Saute tour !
									{% endif %}
								</p>
							{% endif %}
							<p>Tour de :
								{{ turn.getName() }}</p>
							<p>Carte du dessus de la pile :
								{{ topDiscardCard.getColor() }}
								-
								{{ topDiscardCard.getNumber() }}
								{% if topDiscardCard.getNumber() === 12 %}- Carte + 2 !
								{% endif %}
								{% if topDiscardCard.getNumber() === 11 %}- Carte Changement de sens !
								{% endif %}
								{% if topDiscardCard.getNumber() === 10 %}- Carte Saute tour !
								{% endif %}
							</p>
						
							<p>Joueurs</p>
							<ul style="display: flex; justify-content: space-between">
								{% for player in players %}
									<li>
										<p>
											{{ player.getId() }}
											-
											{{ player.getName() }}
											-
											{{ player.getPlayerType() }}
											-
											{{ player.getCards()|length }}
											cartes
										</p>
										<ul>
											{% for card in player.getCards() %}
												{% if player.getPlayerType() === 'user' %}
													<li class="{% if turn.getPlayerType() !== 'user' %}pas-tour{% endif %} ">
														{% if accumulation > 0 %}
															{% if topDiscardCard.getNumber() === 12 and topDiscardCard.getNumber() === card.getNumber() %}
																<a href="{{ path('user_index', {'cardId': card.getId()}) }}">
																	<p>
																		ID :
																		{{ card.getId() }}
																		-
																		{{ card.getNumber() }}
																		-
																		{{ card.getColor() }}
																	</p>
																</a>
															{% else %}
																<p>
																	ID :
																	{{ card.getId() }}
																	-
																	{{ card.getNumber() }}
																	-
																	{{ card.getColor() }}
																</p>
															{% endif %}
														{% else %}
															{% if topDiscardCard.getNumber() === card.getNumber() or topDiscardCard.getColor() === card.getColor() %}
																<a href="{{ path('user_index', {'cardId': card.getId()}) }}">
																	<p>
																		ID :
																		{{ card.getId() }}
																		-
																		{{ card.getNumber() }}
																		-
																		{{ card.getColor() }}
																	</p>
																</a>
															{% else %}
																<p>
																	ID :
																	{{ card.getId() }}
																	-
																	{{ card.getNumber() }}
																	-
																	{{ card.getColor() }}
																</p>
															{% endif %}
														{% endif %}
													</li>
												{% else %}
													<li class="pas-tour">
														{% if accumulation > 0 %}
															{% if topDiscardCard.getNumber() === 12 and topDiscardCard.getNumber() === card.getNumber() %}
																<a href="{{ path('user_index', {'cardId': card.getId()}) }}">
																	<p>
																		ID :
																		{{ card.getId() }}
																		-
																		{{ card.getNumber() }}
																		-
																		{{ card.getColor() }}
																	</p>
																</a>
															{% else %}
																<p>
																	ID :
																	{{ card.getId() }}
																	-
																	{{ card.getNumber() }}
																	-
																	{{ card.getColor() }}
																</p>
															{% endif %}
														{% else %}
															{% if topDiscardCard.getNumber() === card.getNumber() or topDiscardCard.getColor() === card.getColor() %}
																<a href="{{ path('user_index', {'cardId': card.getId()}) }}">
																	<p>
																		ID :
																		{{ card.getId() }}
																		-
																		{{ card.getNumber() }}
																		-
																		{{ card.getColor() }}
																	</p>
																</a>
															{% else %}
																<p>
																	ID :
																	{{ card.getId() }}
																	-
																	{{ card.getNumber() }}
																	-
																	{{ card.getColor() }}
																</p>
															{% endif %}
														{% endif %}
													</li>
												{% endif %}
											{% endfor %}
										</ul>
									</li>
								{% endfor %}
							</ul>
							<p>Défausse</p>
							<ul>
								{% for card in discard %}
									<li>
										<p>
											ID :
											{{ card.getId() }}
											-
											{{ card.getNumber() }}
											-
											{{ card.getColor() }}
										</p>
									</li>
								{% endfor %}
							</ul>
							<p>Deck :
								{{ deck|length }}
								cartes</p>
						
							<ul>
								{% for card in deck %}
									<li>
										<p>
											ID :
											{{ card.getId() }}
											-
											{{ card.getNumber() }}
											-
											{{ card.getColor() }}
										</p>
									</li>
								{% endfor %}
							</ul> #}
	</div>
