{% extends 'base.html.twig' %}

{% block title %}Chargement de la partie{% endblock %}

{% block body %}
<div>
    <h1 id="loading-text" style="color: white; margin-top: 3rem; margin-left: 3rem; font-size: 1.5rem">
        Chargement des cartes... 0%
    </h1>
</div>

<script>
    // musique
    window.parent.postMessage({
        target: "music",
        audioSource: "game",
        loop: true,
    }, "*");

    // nettoyer timers
    if (window.clearPlayTimeouts) {
        window.clearPlayTimeouts();
    }

    const loadingText = document.getElementById("loading-text");

    // liste des images
    const images = [
    {% for color in ['red','yellow','blue','green'] %}
        {% for i in 0..12 %}
        "{{ asset('assets/images/cards/' ~ color ~ '_' ~ i ~ '.webp') }}",
        {% endfor %}
    {% endfor %}

    {% set players = [
    'lucas','emma','noah','lea','hugo','jade','louis','chloe',
    'nathan','manon','enzo','camille','gabriel','sarah','mathis'
    ] %}

    {% for player in players %}
        "{{ asset('assets/images/players/' ~ player ~ '.webp') }}"{% if not loop.last %},{% endif %}
    {% endfor %}
    ];

    async function preloadImages(list) {
        let loaded = 0;

        for (const src of list) {
            const img = new Image();
            img.src = src;

            try {
                await img.decode();
            } catch(e) {
                // ignore erreurs
            }

            loaded++;
            const percent = Math.round((loaded / list.length) * 100);
            loadingText.textContent = "Chargement des cartes... " + percent + "%";
        }
    }

    preloadImages(images).then(() => {
        setTimeout(() => {
            window.location.href = "{{ path('play_index') }}";
            // Turbo.visit("{{ path('play_index') }}", { action: "replace" });
        }, 50);
    });
</script>
{% endblock %}
