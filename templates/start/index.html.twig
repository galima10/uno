{% extends 'base.html.twig' %}

{% block title %}Chargement de la partie
{% endblock %}

{% block body %}
	 <script>
    //  Lancement de la musique de jeu
     window.parent.postMessage(
        {
            target: "music",
            audioSource: "game",
            loop: true,
        },
        "*",
    );
    //  Nettoyer les timers pour éviter une redirection en attente
        if (window.clearPlayTimeouts) {
		    window.clearPlayTimeouts();
		}
        window.location.href = "{{ path('play_index') }}";
    </script>
{% endblock %}
